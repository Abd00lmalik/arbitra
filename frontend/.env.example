# ── Required for Vercel Deployment ─────────────────────────────────────────

# ArbitraInvoiceRegistry contract address on Sepolia (from deploy script output)
NEXT_PUBLIC_REGISTRY_ADDRESS=0x

# Real cUSDT from Zama Wrappers Registry on Sepolia
# Registry: 0x2f0750Bbb0A246059d80e94c454586a7F27a128e
# Resolved cUSDT: call getTokenConfidentialTokenPair(USDT_SEPOLIA) on the registry
NEXT_PUBLIC_CUSDT_ADDRESS=0x4E7B06D78965594eB5EF5414c357ca21E1554491

# Sepolia chain ID
NEXT_PUBLIC_CHAIN_ID=11155111

# ── Server-side only (never expose to browser) ──────────────────────────────

# Google Gemini API key for the /api/risk-assessment route
GEMINI_API_KEY=your_gemini_api_key_here

# Alchemy RPC key for Sepolia (optional, improves reliability)
ALCHEMY_API_KEY=your_alchemy_key_here
